# Copia este archivo como: secrets.revive.env
# NO lo subas a GitHub (.gitignore ya lo excluye)

# GitHub — valechaurig-tech
# Crear en: GitHub → Settings → Developer settings → Personal access tokens → Fine-grained
# Permisos: repositorio ERP_REVIVE_HOGAR (Contents: Read and write)
GH_TOKEN=

# Vercel — cuenta valechaurig-tech
# Crear en: vercel.com → Account Settings → Tokens
VERCEL_TOKEN=

# Opcional: solo si quieres que el script configure variables en Vercel
GEMINI_API_KEY=
